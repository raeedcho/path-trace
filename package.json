{
  "name": "path-trace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --mode default",
    "dev:arc-tracing": "vite --mode arc-tracing-study",
    "build": "vite build --mode default",
    "build:arc-tracing": "vite build --mode arc-tracing-study",
    "build:all": "vite build --mode default && vite build --mode arc-tracing-study",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "firebase": "^12.11.0"
  }
}
